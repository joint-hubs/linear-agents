# Copy to .env (gitignored) and fill. Loaded by bin/_lib.bat.

# --- Providers (Anthropic-compatible endpoints) ---
OPENROUTER_API_KEY=sk-or-v1-________________________
ANTHROPIC_API_KEY=sk-ant-________________________   # for native Anthropic (Opus/Sonnet) path
# Optional direct provider keys (if not routing all via OpenRouter):
ZAI_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# --- Linear ---
LINEAR_API_KEY=lin_api_________________________
LINEAR_TEAM_KEY=               # e.g. JOI / PISI  (TODO: confirm workspace/team)
LINEAR_AGENT_OAUTH_TOKEN=      # bot @flow (OAuth actor=app) for webhooks (TODO)

# --- Deploy targets (TEST agent) ---
GCP_PROJECT=
GCP_ZONE=
GCP_VM_NAME=                   # OpenRouter build deploy target (TODO)
LAMBDA_API_KEY=                # Ollama/GPU build path (TODO)
LAMBDA_INSTANCE=

# --- Guardrails ---
COST_BUDGET_USD_PER_TASK=2.00  # kill-switch threshold (W6)
