{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read", "Grep", "Glob",
      "Bash(git diff:*)", "Bash(git log:*)", "Bash(git show:*)",
      "Bash(semgrep:*)", "Bash(snyk:*)", "Bash(trivy:*)", "Bash(gitleaks:*)", "Bash(npx eslint:*)", "Bash(ruff:*)",
      "mcp__linear__*"
    ],
    "deny": [
      "Edit", "Write", "Bash(git push:*)", "Bash(git commit:*)", "Bash(rm -rf:*)"
    ]
  },
  "mcpServers": {
    "linear": { "type": "sse", "url": "https://mcp.linear.app/sse" }
  }
}
